# ── Python (ETL) ──────────────────────────────
etl/.venv/
__pycache__/
*.pyc
.pytest_cache/

# ── Node / Vite (web) ─────────────────────────
web/node_modules/
web/dist/
*.local

# ── Raw gameplay data (large, provided separately, never committed) ──
# Anchored to repo root so it does NOT match web/public/data (committed assets).
/data/
*.nakama-0

# ── Generated ETL artifacts ──
# COMMITTED intentionally: the dataset is frozen (5 fixed days) and the app is a
# static site with no backend, so the ETL JSON ships as static assets for Vercel.
# Regenerate via `python -m src.main` if the raw data ever changes; do not hand-edit.

# ── OS / editor cruft ─────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Local Claude Code settings (per-machine, not shared) ──
.claude/settings.local.json
